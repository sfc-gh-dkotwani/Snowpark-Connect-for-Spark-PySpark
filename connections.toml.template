# Copy this file to ~/.snowflake/connections.toml and fill in your credentials.
# Then run: chmod 0600 ~/.snowflake/connections.toml

[spark-connect]
host = "<your_account>.snowflakecomputing.com"
account = "<your_account>"
user = "<your_user>"
password = "<your_password>"
warehouse = "<your_warehouse>"
database = "<your_database>"
schema = "public"
